{
  "cli": {
    "version": ">= 12.0.0",
    "promptToConfigurePushNotifications": false
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      }
    },
    "testflight": {
      "distribution": "store",
      "credentialsSource": "remote",
      "ios": {
        "autoIncrement": true
      },
      "env": {
        "EXPO_PUBLIC_USE_MOCK_DATA": "false"
      } 
    },
    "production": {
      "distribution": "store",
      "ios": {
        "autoIncrement": true
      },
      "env": {
        "EXPO_PUBLIC_USE_MOCK_DATA": "false"
      }
    }
  },
  "submit": {
    "testflight": {
      "ios": {
        "appleId": "ahmedsayed.cs2019@gmail.com",
        "ascAppId": "6762006158",
        "appleTeamId": "N3R8MF955Y"
      }
    }
  }
}
