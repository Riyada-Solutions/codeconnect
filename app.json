{
  "expo": {
    "name": "CodeConnect",
    "slug": "codeconnect",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "codeconnect",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2daaae"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.emdadarabia.codeconnect",
      "buildNumber": "1",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Allow CodeConnect to sign you in with Face ID."
      }
    },
    "android": {
      "package": "com.emdadarabia.codeconnect",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/ic_launcher.png",
        "backgroundColor": "#2daaae"
      },
      "softwareKeyboardLayoutMode": "resize"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://codeconnect.app/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "owner": "emdadarabia",
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
