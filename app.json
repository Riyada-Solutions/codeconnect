{
  "expo": {
    "name": "CodeConnect",
    "slug": "codeconnect",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "codeconnect",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2daaae"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.codeconnect",
      "buildNumber": "1",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Allow CodeConnect to sign you in with Face ID.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.codeconnect",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/ic_launcher.png",
        "backgroundColor": "#2daaae"
      },
      "softwareKeyboardLayoutMode": "resize",
      "usesCleartextTraffic": false
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      "./plugins/with-modular-headers.js"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "1ae5d4fe-2950-4061-aeab-a3e2f1920daf"
      }
    }
  }
}
